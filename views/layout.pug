doctype html
html(lang='pl')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title= title
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=Inter:wght@400;500&display=swap')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet' href='/stylesheets/style.css')
  body
    header.site-header
      .inner
        a.site-title(href='/') Archive
        nav.site-nav
          a(href='/galleries') Galerie
          a(href='/docs') Dokumentacja
          if loggedUser === 'admin'
            a(href='/users') Użytkownicy
          span.nav-divider
          if loggedUser
            span.nav-user= loggedUser
            a(href='/users/user_logout') Wyloguj
          else
            a(href='/users/user_login') Zaloguj
            a(href='/users/user_register') Rejestracja

    main
      block content

    footer.site-footer
      .footer-inner
        span.footer-brand Archive
        span Platforma galerii &copy; #{new Date().getFullYear()}
        a(href='/docs') Dokumentacja

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
